{
	"name": "williamstownsc",
	"version": "1.0.0",
	"private": true,
	"packageManager": "pnpm@11.5.2",
	"scripts": {
		"dev": "next dev --port 3003",
		"build": "pnpm run type:gen && next build",
		"build:sanity": "sanity build",
		"deploy:sanity": "sanity deploy",
		"start": "next start",
		"lint": "eslint",
		"lint-staged": "lint-staged",
		"format": "prettier . --write .",
		"format:check": "prettier . --check",
		"prepare": "husky",
		"type:gen": "sanity schema extract --path src/sanity && sanity typegen generate",
		"type:check": "tsc --noEmit",
		"crawl:clubs": "dotenv -e .env.local -- tsx bin/wsc.ts crawl clubs",
		"crawl:clubs:ci": "xvfb-run --auto-servernum tsx bin/wsc.ts crawl clubs",
		"crawl:fixtures": "dotenv -e .env.local -- tsx bin/wsc.ts crawl fixtures",
		"crawl:fixtures:ci": "xvfb-run --auto-servernum tsx bin/wsc.ts crawl fixtures",
		"sync:clubs": "dotenv -e .env.local -- tsx bin/wsc.ts sync clubs",
		"sync:fixtures": "dotenv -e .env.local -- tsx bin/wsc.ts sync fixtures",
		"sync:table": "dotenv -e .env.local -- tsx bin/wsc.ts sync table",
		"sync:table:ci": "tsx bin/wsc.ts sync table",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:debug": "playwright test --debug",
		"test:e2e:report": "playwright show-report"
	},
	"dependencies": {
		"@aws-sdk/client-ses": "3.1063.0",
		"@date-fns/tz": "1.5.0",
		"@fontsource/exo": "5.2.8",
		"@fontsource/outfit": "5.2.8",
		"@next/third-parties": "16.2.7",
		"@portabletext/toolkit": "5.0.2",
		"@portabletext/types": "4.0.2",
		"@sanity/client": "7.22.1",
		"@sanity/icons": "3.7.4",
		"@sanity/image-url": "2.1.1",
		"@sanity/ui": "3.2.0",
		"@sanity/vision": "5.30.0",
		"@sentry/nextjs": "10.56.0",
		"@tanstack/react-query": "5.101.0",
		"@tanstack/react-query-devtools": "5.101.0",
		"clsx": "2.1.1",
		"daisyui": "5.5.23",
		"date-fns": "4.4.0",
		"lucide-react": "1.17.0",
		"next": "16.2.7",
		"next-sanity": "13.0.11",
		"pino": "10.3.1",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"react-hook-form": "7.78.0",
		"sanity": "5.30.0",
		"styled-components": "6.4.2",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@faker-js/faker": "10.4.0",
		"@playwright/test": "1.60.0",
		"@tailwindcss/postcss": "4.3.0",
		"@trivago/prettier-plugin-sort-imports": "6.0.2",
		"@types/node": "25.0.5",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"commander": "15.0.0",
		"dotenv": "17.4.2",
		"dotenv-cli": "11.0.0",
		"eslint": "9.39.4",
		"eslint-config-next": "16.2.7",
		"eslint-config-prettier": "10.1.8",
		"eslint-import-resolver-typescript": "4.4.5",
		"eslint-plugin-import": "2.32.0",
		"husky": "9.1.7",
		"lint-staged": "17.0.7",
		"pino-pretty": "13.1.3",
		"playwright-core": "1.60.0",
		"prettier": "3.8.3",
		"prettier-plugin-tailwindcss": "0.8.0",
		"tailwindcss": "4.3.0",
		"tsx": "4.22.4",
		"typescript": "6.0.3"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,json}": [
			"prettier . --write",
			"eslint ."
		]
	},
	"browserslist": "> 1%"
}
