{
	"name": "williamstownsc",
	"version": "1.0.0",
	"private": true,
	"packageManager": "pnpm@10.33.2",
	"scripts": {
		"dev": "next dev --port 3003",
		"build": "pnpm run type:gen && next build",
		"build:sanity": "sanity build",
		"deploy:sanity": "sanity deploy",
		"start": "next start",
		"lint": "eslint",
		"lint-staged": "lint-staged",
		"format": "prettier . --write .",
		"format:check": "prettier . --check",
		"prepare": "husky",
		"type:gen": "sanity schema extract --path src/sanity && sanity typegen generate",
		"type:check": "tsc --noEmit",
		"crawl:clubs": "dotenv -e .env.local -- tsx bin/wsc.ts crawl clubs",
		"crawl:clubs:ci": "xvfb-run --auto-servernum tsx bin/wsc.ts crawl clubs",
		"crawl:fixtures": "dotenv -e .env.local -- tsx bin/wsc.ts crawl fixtures",
		"crawl:fixtures:ci": "xvfb-run --auto-servernum tsx bin/wsc.ts crawl fixtures",
		"sync:clubs": "dotenv -e .env.local -- tsx bin/wsc.ts sync clubs",
		"sync:fixtures": "dotenv -e .env.local -- tsx bin/wsc.ts sync fixtures",
		"sync:table": "dotenv -e .env.local -- tsx bin/wsc.ts sync table",
		"sync:table:ci": "tsx bin/wsc.ts sync table",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:debug": "playwright test --debug",
		"test:e2e:report": "playwright show-report"
	},
	"dependencies": {
		"@aws-sdk/client-ses": "3.1023.0",
		"@date-fns/tz": "1.4.1",
		"@fontsource/exo": "5.2.8",
		"@fontsource/outfit": "5.2.8",
		"@next/third-parties": "16.2.2",
		"@portabletext/toolkit": "5.0.2",
		"@portabletext/types": "4.0.2",
		"@sanity/client": "7.20.0",
		"@sanity/icons": "3.7.4",
		"@sanity/image-url": "2.1.1",
		"@sanity/ui": "3.1.14",
		"@sanity/vision": "5.19.0",
		"@sentry/nextjs": "10.47.0",
		"@tanstack/react-query": "5.96.1",
		"@tanstack/react-query-devtools": "5.96.1",
		"clsx": "2.1.1",
		"daisyui": "5.5.19",
		"date-fns": "4.1.0",
		"lucide-react": "1.7.0",
		"next": "16.2.2",
		"next-sanity": "12.2.1",
		"pino": "10.3.1",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"react-hook-form": "7.72.0",
		"sanity": "5.19.0",
		"styled-components": "6.3.12",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@faker-js/faker": "10.4.0",
		"@playwright/test": "1.59.1",
		"@tailwindcss/postcss": "4.2.2",
		"@trivago/prettier-plugin-sort-imports": "6.0.2",
		"@types/node": "25.0.5",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"commander": "14.0.3",
		"dotenv": "17.4.0",
		"dotenv-cli": "11.0.0",
		"eslint": "9.39.4",
		"eslint-config-next": "16.2.2",
		"eslint-config-prettier": "10.1.8",
		"eslint-import-resolver-typescript": "4.4.4",
		"eslint-plugin-import": "2.32.0",
		"husky": "9.1.7",
		"lint-staged": "16.4.0",
		"pino-pretty": "13.1.3",
		"playwright-core": "1.59.1",
		"prettier": "3.8.1",
		"prettier-plugin-tailwindcss": "0.7.2",
		"tailwindcss": "4.2.2",
		"tsx": "4.21.0",
		"typescript": "6.0.2"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,json}": [
			"prettier . --write",
			"eslint ."
		]
	},
	"browserslist": "> 1%",
	"pnpm": {
		"onlyBuiltDependencies": [
			"@sentry/cli",
			"esbuild",
			"sharp",
			"unrs-resolver"
		]
	}
}
